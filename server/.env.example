# Copy to .env and fill in values. Never commit .env.

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# In .env, # starts a comment unless the value is quoted. If your password contains #, use:
# MYSQL_PASSWORD="your_password_with#hash"
MYSQL_PASSWORD="Qe24#546"
MYSQL_DATABASE=expense_tracker

PORT=4000
LOG_LEVEL=info
# Must match the browser origin (Next.js dev is usually port 3000).
CORS_ORIGIN=http://localhost:3000
